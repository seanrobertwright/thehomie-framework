# === Vault Location ===
# Path to your Obsidian-style memory vault. Defaults to the checked-in vault
# inside the cloned repo. Set this to point at a vault outside the repo
# (the normal case for personal use of the open-source framework).
#
# Accepts:
#   - Absolute paths:    HOMIE_VAULT_DIR=C:/Users/me/vaults/homie
#   - ~-expandable:      HOMIE_VAULT_DIR=~/vaults/homie
#   - Relative paths:    HOMIE_VAULT_DIR=./my-vault   (resolved against cwd, not repo root)
#
# HOMIE_VAULT_DIR=

# === Owner ===
# Your name - used in prompts and notifications (e.g., "Cole's meeting in 30 min")
OWNER_NAME=

# === Business Profile (Optional but recommended) ===
# Used for heartbeat summaries, HARO drafting, social account labels, and inbox protection.
BUSINESS_NAME=
BUSINESS_FOUNDER_NAME=
BUSINESS_EMAIL=
BUSINESS_PHONE=
BUSINESS_ADDRESS=
BUSINESS_WEBSITE=
BUSINESS_DOMAIN=
BUSINESS_DESCRIPTION=
BUSINESS_AI_CREDENTIALS=
BUSINESS_DOMAIN_CREDENTIALS=
# Comma-separated lists
PROTECTED_ADDRESSES=
KEEP_DOMAINS=
# Optional social/account labels
X_HANDLE=
FACEBOOK_PAGE_NAME=
INSTAGRAM_HANDLE=
LINKEDIN_PAGE_NAME=
YELP_PAGE_NAME=
BBB_PAGE_NAME=
WALLETHUB_PAGE_NAME=

# === Authentication ===
# Claude Agent SDK uses Claude Code CLI authentication automatically.
# If you've run `claude` and logged in, no config needed!
#
# Task Scheduler runs as your user, so it uses your existing credentials
# stored in ~/.claude/.credentials.json
#
# Only set these if you need to override the default auth:
# ANTHROPIC_API_KEY=sk-ant-...           # For direct API billing
# CLAUDE_CODE_OAUTH_TOKEN=...            # For containers/CI (not needed locally)

# === Database ===
# Leave empty to use local SQLite (default). Set for Postgres (VPS deployment).
# DATABASE_URL=postgresql://thehomie:changeme@localhost:5432/thehomie

# === Chat Runtime ===
# Whole-turn guard for interactive chat surfaces. Keep this above provider
# subprocess timeouts so Telegram/Slack can return an operational error instead
# of hanging indefinitely.
CHAT_ENGINE_TIMEOUT_SECONDS=180

# Attachment full-read caps (doc-upload-truthful-reads Phase 2). Uploaded
# document text rides the turn prompt up to these caps; anything clipped is
# disclosed to the model as PARTIAL CONTENT. Reloadable via /reload.
# Defaults shown.
# CHAT_ATTACHMENT_MAX_BYTES=8388608             # per-file parser byte limit (8 MiB)
# CHAT_ATTACHMENT_MAX_CHARS=100000              # per-attachment extracted-text cap
# CHAT_ATTACHMENT_TOTAL_MAX_CHARS=120000        # whole-turn attachment context budget
# CHAT_ENGINE_ATTACHMENT_TIMEOUT_SECONDS=300    # engine timeout for turns with attachments

# === Observability ===
LANGFUSE_ENABLED=
LANGFUSE_BASE_URL=
LANGFUSE_OTEL_TIMEOUT_SECONDS=1

# === Heartbeat Configuration ===
HEARTBEAT_INTERVAL_MINUTES=30
HEARTBEAT_ACTIVE_HOURS_START=08:00
HEARTBEAT_ACTIVE_HOURS_END=22:00
HEARTBEAT_TIMEZONE=America/Chicago

# Note: Model is determined by your Claude subscription (claude_code preset)
# The heartbeat uses full Claude Code capabilities including all your skills

# === Reflection Configuration ===
REFLECTION_HOUR=8

# === Evolve (Self-Improvement Loop) ===
# Phase 2.4: when true, `evolve run` and `evolve propose` default to emitting
# Langfuse-tagged spans under user_id="evolve-replay" so experimental traces
# can be filtered out of production cost reports. Override per-invocation
# via --trace / --no-trace on the CLI. Filter the Langfuse UI by
# user_id="evolve-replay" or sessionId="evolve:<experiment_id>".
EVOLVE_TRACE_REPLAYS=false

# === Phase 5: Direct Platform Integrations ===

# Asana (Personal Access Token from https://app.asana.com/0/developer-console)
ASANA_ACCESS_TOKEN=
ASANA_WORKSPACE_ID=
ASANA_PROJECT_ID=
# Friendly name to Asana GID mapping (format: name:gid,name:gid)
ASANA_USERS=

# Slack Bot Token
# Setup:
#   1. Go to https://api.slack.com/apps -> "Create New App" -> "From Scratch"
#   2. Name it "The Homie" (or whatever you like), pick your workspace
#   3. Go to "OAuth & Permissions" in the left sidebar
#   4. Scroll to "Scopes" -> "Bot Token Scopes" and add these 5 scopes:
#        channels:read        (list public channels)
#        channels:history     (read messages in public channels)
#        chat:write           (send messages)
#        chat:write.public    (send to channels the bot hasn't joined)
#        users:read           (resolve user IDs to display names)
#   5. Scroll up and click "Install to Workspace" -> "Allow"
#   6. Copy the "Bot User OAuth Token" (starts with xoxb-)
#   7. Paste it below
#   8. (Optional) Create a #thehomie channel for heartbeat notifications
SLACK_BOT_TOKEN=
SLACK_OWNER_USER_ID=
SLACK_NOTIFICATION_CHANNEL=
SLACK_MONITORED_CHANNELS=

# Slack App Token (for Socket Mode — chat interface)
# Setup:
#   1. Go to your Slack app settings -> "Basic Information"
#   2. Scroll to "App-Level Tokens" -> "Generate Token and Scopes"
#   3. Name it (e.g. "socket-mode"), add scope: connections:write
#   4. Generate -> copy the token (starts with xapp-)
#   5. Enable Socket Mode: Settings -> "Socket Mode" -> toggle on
#   6. Add bot scopes: OAuth & Permissions -> add:
#        app_mentions:read    (receive @bot mentions)
#        im:read              (read DM metadata)
#        im:history           (read DM messages)
#   7. Subscribe to events: Event Subscriptions -> toggle on -> Bot Events -> add:
#        app_mention          (when someone @mentions the bot)
#        message.im           (when someone DMs the bot)
#   8. Reinstall app to workspace (Slack prompts you after scope changes)
SLACK_APP_TOKEN=

# Telegram (Chat Interface)
# Setup:
#   1. Message @BotFather to create a bot and copy the token
#   2. Add your user ID(s) to restrict access (comma-separated)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# Voice notes
# STT defaults to free/local-first providers and does not spend OpenAI quota
# just because OPENAI_API_KEY is present for runtime/model calls.
# Optional explicit order: groq,faster_whisper,whisper_cpp,mistral
VOICE_STT_PROVIDERS=
# Set to 1 only when you intentionally want OpenAI Whisper in the STT cascade.
VOICE_STT_ENABLE_OPENAI=
FASTER_WHISPER_MODEL=base
VOICE_TTS_ENGINE=edge
VOICE_TTS_VOICE_EDGE=en-US-GuyNeural

# Google OAuth (Gmail + Calendar)
# Setup:
#   1. Go to https://console.cloud.google.com -> create/select a project
#   2. Enable BOTH APIs (search each in the top bar -> click Enable):
#        - Gmail API
#        - Google Calendar API
#   3. Go to "APIs & Services" -> "OAuth consent screen"
#        - User type: "External" (required for custom domains)
#        - Fill in app name, support email, save
#        - Click "Publish App" to move to Production (avoids 7-day token expiry)
#   4. Go to "APIs & Services" -> "Credentials" -> "Create Credentials" -> "OAuth client ID"
#        - Application type: "Desktop app"
#        - Download the JSON file
#        - Save as: .claude/scripts/integrations/google_credentials.json
#   5. Run: cd .claude/scripts && uv run python setup_auth.py
#        - Browser opens for OAuth consent -> authorize
#        - Token auto-saved to .claude/scripts/integrations/google_token.json
GOOGLE_CALENDAR_ID=

# Microsoft Graph / Outlook mailbox
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
GRAPH_USER_EMAIL=

# Circle (Community Platform)
# Setup:
#   1. Go to your Circle community → Developers → Tokens
#   2. Create a token with type "Admin V2" → paste below as CIRCLE_ADMIN_TOKEN
#   3. Create a token with type "Headless Auth" → paste below as CIRCLE_HEADLESS_TOKEN
#   4. Set CIRCLE_MEMBER_EMAIL to your Circle account email
CIRCLE_ADMIN_TOKEN=
CIRCLE_HEADLESS_TOKEN=
CIRCLE_MEMBER_EMAIL=
CIRCLE_COMMUNITY_MEMBER_ID=

# === PRD-8 Phase 7a: Operator Kill-Switches ===
# Set to 'disabled' (case-insensitive) to gate features. Default: enabled.
# Refusal counts visible via /api/health killSwitches.counters field. Process-
# local — counters reset on restart (see /api/health killSwitches.process_started_at).
# Each refusal also writes a row to .claude/data/dashboard.db audit_log table
# (action='killswitch_refusal').
# HOMIE_KILLSWITCH_LLM=
# HOMIE_KILLSWITCH_RECALL=

# === PRD-8 Phase 7b: New Kill-Switches (voice + persona) ===
# HOMIE_KILLSWITCH_VOICE=             # gates voice.transcribe_audio_file/synthesize/legacy transcribe
# HOMIE_KILLSWITCH_PERSONA_MUTATION=  # gates lifecycle create/delete/use_profile + 9 HTTP state-mutation routes
# HOMIE_KILLSWITCH_PERSONA_OPERATIONS=# gates 3 HTTP runtime-lifecycle routes (activate/deactivate/restart)
# HOMIE_KILLSWITCH_CABINET=           # gates cabinet chat-process handlers (commit-2 — post Phase 5b merge)

# === PRD-8 Phase 7b: Secret Redaction (default ON, matches Hermes verbatim) ===
# Hermes agent/redact.py:60 idiom: unset env → empty string → NOT in the
# disabled tuple ('0','false','no','off') → _REDACT_ENABLED snapshots True.
# Operator opts OUT (e.g. for triage / debug where masked output is hard to
# read) by uncommenting the line below. Accepts: 0, false, no, off.
# HOMIE_REDACT_SECRETS=false

# === PRD-8 Phase 7a: Audit-Log Endpoint Admin Token (R2 NM5) ===
# REQUIRED to enable GET /api/audit-log. When unset, the endpoint returns 503
# (fail-closed). This is a SEPARATE bearer token from ORCHESTRATION_API_TOKEN —
# /api/audit-log is exempt from the outer middleware so the admin token is the
# SOLE auth path (no token-layering ambiguity). Generate with:
#     openssl rand -hex 32
# DASHBOARD_ADMIN_TOKEN=

# === Claude Code OAuth (CI / container deploys) ===
# CLAUDE_CODE_OAUTH_TOKEN — used by some CI/container deploys instead of
# the local ~/.claude/.credentials.json file. Whitelisted in
# runtime/subprocess_env.py:_BOT_CREDS_PREFIXES so persona-bot subprocesses
# inherit it. CLAUDE_CONFIG_DIR — overrides the Claude Agent SDK config-dir
# lookup (preserved by Max OAuth carve-out).
# CLAUDE_CODE_OAUTH_TOKEN=
# CLAUDE_CONFIG_DIR=
