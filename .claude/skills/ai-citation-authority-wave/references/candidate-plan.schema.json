{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thehomie.ai/schemas/ai-citation-authority/candidate-plan.schema.json",
  "title": "AI Citation Authority Candidate Plan",
  "type": "object",
  "required": ["schema_version", "status", "targets"],
  "properties": {
    "schema_version": { "const": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["ready", "no_evidence"] },
    "targets": {
      "type": "array",
      "maxItems": 3,
      "items": { "$ref": "#/$defs/target" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "ready" } } },
      "then": { "properties": { "targets": { "minItems": 1 } } }
    },
    {
      "if": { "properties": { "status": { "const": "no_evidence" } } },
      "then": { "properties": { "targets": { "maxItems": 0 } } }
    }
  ],
  "$defs": {
    "target": {
      "type": "object",
      "required": [
        "id",
        "mode",
        "locale",
        "query",
        "title",
        "slug",
        "route",
        "output_path",
        "evidence_refs",
        "sources",
        "direct_answer_sentences",
        "headings",
        "internal_links",
        "brand_role_passage"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
        "mode": { "enum": ["reddit_modifier", "direct_answer", "comparison"] },
        "locale": { "enum": ["en", "es"] },
        "query": { "type": "string", "minLength": 3 },
        "title": { "type": "string", "minLength": 3 },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "route": { "type": "string", "pattern": "^/" },
        "output_path": { "type": "string", "minLength": 1 },
        "evidence_refs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
        "sources": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["url", "use"],
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "use": { "type": "string", "minLength": 1 },
              "source_type": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "direct_answer_sentences": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "string", "minLength": 10 }
        },
        "headings": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 3 }
        },
        "internal_links": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^/" }
        },
        "brand_role_passage": { "type": "string", "minLength": 20 },
        "search_intent": { "type": "string" },
        "differentiation": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
